# AlphaSign32 Build Configuration
# Copy this file to .env and customize as needed
# All values are optional - defaults will be used if not specified

# ===================================
# Serial/UART Pin Configuration
# ===================================
# GPIO pins for communication with the Alpha sign
# Default pins work with most ESP32 boards
ALPHASIGN_RX_PIN=16
ALPHASIGN_TX_PIN=17
POWER_CONTROL_PIN=5

# ===================================
# Debug Settings
# ===================================
# Serial monitor baud rate for debug output
DEBUG_SERIAL_BAUD=115200

# Enable debug output (true/false)
# When true, packet details are printed to Serial
ENABLE_DEBUG=false

# ===================================
# Timing Configuration
# ===================================
# System monitor update interval in milliseconds
# How often to refresh system stats display
MONITOR_INTERVAL_MS=5000

# Serial connection timeout in milliseconds
# How long to wait for Serial connection on startup
SERIAL_TIMEOUT_MS=3000

# ===================================
# WiFi Configuration (optional)
# ===================================
# WiFi SSID for network connection (optional, for NTP time or remote monitoring)
WIFI_SSID=YourSSID
WIFI_PASSWORD=YourPassword

# ===================================
# OTA Configuration
# ===================================
# Hostname for mDNS (access device at http://hostname.local)
OTA_HOSTNAME=alphasign32
